{
  "files.associations": {
    "*.cpp": "cpp",
    "*.cc": "cpp",
    "*.cxx": "cpp",
    "*.hpp": "cpp",
    "*.hh": "cpp",
    "*.hxx": "cpp"
  },
  "C_Cpp.default.compileCommands": "${workspaceFolder}/cpp/build-local/compile_commands.json",
  "C_Cpp.default.intelliSenseMode": "macos-clang-arm64",
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.default.cppStandard": "c++20",
  "C_Cpp.default.compilerPath": "/usr/bin/c++",
  "clangd.path": "/opt/homebrew/opt/llvm/bin/clangd",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/cpp/build-local",
    "--background-index",
    "--clang-tidy",
    "--header-insertion=never"
  ]
}
